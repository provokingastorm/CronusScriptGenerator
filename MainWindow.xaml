<Window x:Class="WpfTextTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cronus Script Generator"
        Height="480" Width="480"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F9FAFB"/>
                                <Setter Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- NumberInput TextBox Style -->
        <Style x:Key="NumberInput" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Cronus Script Generator"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#111827"/>

        <!-- Import / Export Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal">

            <Button x:Name="ExportButton"
                    Content="⬇  Generate Cronus Script"
                    Style="{StaticResource PrimaryButton}"
                    Click="ExportButton_Click"/>
            
            <Button x:Name="ImportButton"
                    Content="⬆  Import Input Sequence"
                    Style="{StaticResource SecondaryButton}"
                    Click="ImportButton_Click"
                    Margin="12,0,12,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.RowSpan="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom">

            <TextBlock Text="Input Button Sequence:"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Grid.RowSpan="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom">

            <TextBox x:Name="SequenceTextBox"
                     VerticalScrollBarVisibility="Visible"
                     Width="400"
                     Height="100"
                     MaxLength="100"
                     Margin="0,0,8,0"
                     VerticalAlignment="Top"
                     CharacterCasing="Upper"
                     PreviewTextInput="ButtonSequenceTextBox_TextInput"
                     DataObject.Pasting="TimeDelayTextBox_Pasting"/>
        </StackPanel>

        <!-- Input Sequence Configuration Options -->
        <StackPanel Grid.Row="4" Orientation="Horizontal">

            <TextBox x:Name="RepeatSequenceTextBox"
                         Style="{StaticResource NumberInput}"
                         Width="72"
                         Height="50"
                         MaxLength="5"
                         Text="1"
                         Margin="0,8,8,8"
                         PreviewTextInput="TimeDelayTextBox_TextInput"
                         DataObject.Pasting="TimeDelayTextBox_Pasting"/>

            <TextBlock Text="Repeat input"
                       FontSize="12"
                       Foreground="#374151"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="InputDelayTextBox"
                     Style="{StaticResource NumberInput}"
                     Width="72"
                     Height="50"
                     MaxLength="5"
                     Text="500"
                     Margin="20,0,8,0"
                     PreviewTextInput="TimeDelayTextBox_TextInput"
                     DataObject.Pasting="TimeDelayTextBox_Pasting"/>

            <TextBlock Text="Input delay (ms)"
                       FontSize="12"
                       Foreground="#374151"
                       VerticalAlignment="Center"/>
        </StackPanel>
        
        <!-- Add Input Sequence Button -->
        <StackPanel Grid.Row="5"  Grid.RowSpan="2"
                    Orientation="Horizontal">
            
            <Button x:Name="AddInputSequenceButton"
                    Content="Add Input Sequence"
                    Style="{StaticResource SecondaryButton}"
                    Click="AddInputSequenceButton_Click"/>
        </StackPanel>

    </Grid>
</Window>
